{
  "mcpServers": {
    "smart-tree": {
      "command": "st",
      "args": ["--mcp"]
    },
    "text-editor": {
      "command": "uvx",
      "args": ["--python", "3.12", "mcp-text-editor"]
    },
    "mindmap": {
      "command": "uvx",
      "args": ["mindmap-mcp-server", "--return-type", "filePath"]
    },
    "markmap": {
      "command": "npx",
      "args": ["-y", "@jinzcdev/markmap-mcp-server"]
    },
    "devrag": {
      "command": "devrag",
      "args": ["-config", ".claude/devrag.json"]
    }
  }
}
