{
  "formulas": [
    {
      "name": "my-ruby-tool",
      "desc": "A Ruby CLI tool",
      "homepage": "https://github.com/example/my-ruby-tool",
      "url": "https://github.com/example/my-ruby-tool/archive/refs/tags/v1.0.0.tar.gz",
      "sha256": "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855",
      "license": "MIT",
      "language": "custom",
      "livecheck": {
        "url": ":stable",
        "strategy": ":github_latest"
      },
      "dependencies": [
        { "name": "ruby" }
      ],
      "install": {
        "commands": ["ENV[\"GEM_HOME\"] = libexec.to_s", "system \"gem\", \"build\", Dir[\"*.gemspec\"].first", "system \"gem\", \"install\", \"--no-document\", Dir[\"*.gem\"].first", "bin.install Dir[libexec/\"bin/*\"]"]
      },
      "test": {
        "command": "system bin/\"my-ruby-tool\", \"--version\"",
        "expected_output": "my-ruby-tool"
      }
    }
  ]
}
