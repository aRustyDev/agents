# Development Tools
brew "swiftlint"          # Swift linting (used by ios-mcp-code-quality-server)
brew "swiftformat"        # Swift formatting
brew "xcbeautify"         # Xcode build output formatter

# Node.js (for npx-based MCP servers)
brew "node"
