{
  "mcpServers": {
    "sketch-context": {
      "command": "npx",
      "args": ["-y", "sketch-context-mcp"]
    },
    "penpot": {
      "command": "node",
      "args": ["${HOME}/.local/share/penpot-mcp/dist/index.js"],
      "env": {
        "PENPOT_MCP_PORT": "4401"
      }
    },
    "cupertino": {
      "command": "cupertino",
      "args": ["serve"]
    },
    "swift-patterns": {
      "command": "npx",
      "args": ["-y", "swift-patterns-mcp@latest"]
    },
    "xcodebuild": {
      "command": "uvx",
      "args": ["mcpxcodebuild"]
    },
    "simctl": {
      "command": "npx",
      "args": ["-y", "simctl-mcp"]
    },
    "apple-hig": {
      "command": "npx",
      "args": ["-y", "apple-dev-mcp"]
    },
    "xcodeproj": {
      "command": "docker",
      "args": [
        "run", "--rm", "-i",
        "-v", "${workspaceFolder}:/workspace",
        "ghcr.io/giginet/xcodeproj-mcp-server:latest",
        "/workspace"
      ]
    },
    "app-store-connect": {
      "command": "npx",
      "args": ["-y", "appstore-connect-mcp-server"],
      "env": {
        "APP_STORE_CONNECT_KEY_ID": "${APP_STORE_CONNECT_KEY_ID}",
        "APP_STORE_CONNECT_ISSUER_ID": "${APP_STORE_CONNECT_ISSUER_ID}",
        "APP_STORE_CONNECT_P8_PATH": "${APP_STORE_CONNECT_P8_PATH}"
      }
    }
  }
}
