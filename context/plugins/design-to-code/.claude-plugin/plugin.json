{
  "name": "design-to-code",
  "version": "0.1.0",
  "description": "Bridge design tools and code generation, enabling seamless translation of design files into production-ready UI code across multiple frameworks.",
  "author": {
    "name": "Adam Smith",
    "email": "developer@gh.arusty.dev",
    "url": "https://im.arusty.dev"
  },
  "homepage": "https://docs.arusty.dev/ai/plugins/design-to-code",
  "repository": "https://github.com/aRustyDev/ai.git",
  "license": "MIT",
  "keywords": [
    "design-tokens",
    "figma",
    "sketch",
    "penpot",
    "swiftui",
    "react",
    "flutter",
    "tailwind",
    "design-system",
    "code-generation"
  ],
  "commands": [
    "./commands/extract-tokens.md",
    "./commands/generate-component.md",
    "./commands/sync-design-system.md",
    "./commands/export-assets.md",
    "./commands/compare-design.md"
  ],
  "agents": [
    "./agents/design-translator.md",
    "./agents/design-system-architect.md",
    "./agents/asset-pipeline.md"
  ],
  "skills": [
    "./skills/design-tokens-extraction/SKILL.md",
    "./skills/design-to-swiftui/SKILL.md",
    "./skills/design-system-management/SKILL.md",
    "./skills/design-to-react/SKILL.md",
    "./skills/design-to-flutter/SKILL.md",
    "./skills/design-to-tailwind/SKILL.md",
    "./skills/asset-optimization/SKILL.md",
    "./skills/accessibility-audit/SKILL.md"
  ],
  "mcpServers": "./.mcp.json",
  "outputStyles": [
    "./styles/feedback-submission.md",
    "./styles/design-token-json.md",
    "./styles/design-token-swift.md",
    "./styles/design-token-css.md",
    "./styles/design-token-tailwind.md",
    "./styles/component-spec.md"
  ],
  "lspServers": "./.lsp.json"
}
