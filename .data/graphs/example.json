      }
    },
    {
      "id": "node-feature-extraction",
      "type": "Concept",
      "label": "Feature Extraction",
      "properties": {
        "domain": "ML",
        "stage": "preprocessing"
      }
    },
    {
      "id": "node-model-training",
      "type": "Concept",
      "label": "Model Training",
      "properties": {
        "domain": "ML",
        "stage": "training"
      }
    },
    {
      "id": "node-hyperparameter-tuning",
      "type": "Concept",
      "label": "Hyperparameter Tuning",
      "properties": {
        "domain": "ML",
        "stage": "training"
      }
    },
    {
      "id": "node-model-evaluation",
      "type": "Concept",
      "label": "Model Evaluation",
      "properties": {
        "domain": "ML",
        "stage": "validation"
      }
    },
    {
      "id": "node-model-registry",
      "type": "Component",
      "label": "Model Registry",
      "properties": {
        "tool": "MLflow",
        "version": "2.10"
      }
    },
    {
      "id": "node-inference-server",
      "type": "Component",
      "label": "Inference Server",
      "properties": {
        "tool": "Triton",
        "protocol": "gRPC"
      }
    },
    {
      "id": "node-gpu-cluster",
      "type": "Component",
      "label": "GPU Cluster",
      "properties": {
        "provider": "on-prem",
        "gpus": 8,
        "type": "A100"
      }
    },
    {
      "id": "node-data-lake",
      "type": "Component",
      "label": "Data Lake",
      "properties": {
        "storage": "S3",
        "format": "parquet"
      }
    },
    {
      "id": "node-feature-store",
      "type": "Component",
      "label": "Feature Store",
      "properties": {
        "tool": "Feast",
        "online": true
      }
    },
    {
      "id": "node-monitoring",
      "type": "Component",
      "label": "Model Monitoring",
      "properties": {
        "tool": "Evidently",
        "alerts": true
      }
    },
    {
      "id": "node-api-spec",
      "type": "Document",
      "label": "API Specification",
      "properties": {
        "format": "openapi",
        "version": "3.1"
      }
    },
    {
      "id": "node-runbook",
      "type": "Document",
      "label": "Operations Runbook",
      "properties": {
        "format": "markdown",
        "pages": 24
      }
    },
    {
      "id": "node-data-schema",
      "type": "Document",
      "label": "Data Schema",
      "properties": {
        "format": "json-schema",
        "entities": 12
      }
    },
    {
      "id": "node-loss-function",
      "type": "Fragment",
      "label": "Loss Function",
      "properties": {
        "type": "cross-entropy",
        "weighted": true
      }
    },
    {
      "id": "node-optimizer",
      "type": "Fragment",
      "label": "Optimizer Config",
      "properties": {
        "type": "AdamW",
        "lr": 0.001
      }
    },
    {
      "id": "node-data-pipeline",
      "type": "Fragment",
      "label": "ETL Pipeline Config",
      "properties": {
        "schedule": "hourly",
        "retries": 3
      }
    },
    {
      "id": "node-serving-config",
      "type": "Fragment",
      "label": "Serving Configuration",
      "properties": {
        "replicas": 3,
        "autoscale": true
      }
    }
