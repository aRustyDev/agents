{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "name": "AI Context Library",
  "description": "Spell checking configuration for Claude Code context files",
  "dictionaries": [
    "typescript",
    "python",
    "bash",
    "go",
    "rust",
    "css",
    "html",
    "npm",
    "node",
    "softwareTerms",
    "companies",
    "misc"
  ],
  "ignorePaths": [
    "node_modules/**",
    ".venv/**",
    "*.lock",
    "*.sql",
    ".data/**",
    "dist/**",
    "build/**",
    "coverage/**",
    "*.min.*",
    ".git/**"
  ],
  "ignoreRegExpList": [
    "```[\\s\\S]*?```",
    "`[^`]+`",
    "\\[.*?\\]\\(.*?\\)",
    "https?://\\S+",
    "/[\\w-]+/[\\w-]+",
    "\\w+@\\w+\\.\\w+",
    "[a-f0-9]{7,40}",
    "\\$\\{.*?\\}",
    "\\{\\{.*?\\}\\}"
  ],
  "words": [
    "arustydev",
    "anthropic",
    "biome",
    "brewfile",
    "cclint",
    "codecov",
    "codebase",
    "codebases",
    "codegraph",
    "cspell",
    "devrag",
    "embeddings",
    "fastmcp",
    "gitignore",
    "gopls",
    "haiku",
    "justfile",
    "lychee",
    "markdownify",
    "markmap",
    "modelcontextprotocol",
    "nomic",
    "ollama",
    "orbstack",
    "pydantic",
    "pylsp",
    "pyproject",
    "radon",
    "ripgrep",
    "rumdl",
    "semgrep",
    "shfmt",
    "shellcheck",
    "shellharden",
    "smithery",
    "sonnet",
    "sqlfluff",
    "sqlite",
    "subagent",
    "surrealdb",
    "tokei",
    "trafilatura",
    "treesitter",
    "uvx",
    "yamllint",
    "frontmatter",
    "pyupgrade",
    "capitalisation",
    "templater",
    "ctes",
    "isort",
    "autofixable",
    "autofix",
    "fixable",
    "unfixable",
    "flake",
    "docstrings",
    "pydocstyle",
    "mccabe",
    "pylint",
    "builtins",
    "dunder",
    "getattr",
    "pathlib",
    "adrienverge",
    "lycheeverse",
    "biomejs",
    "astral"
  ],
  "flagWords": [],
  "overrides": [
    {
      "filename": "**/*.md",
      "dictionaries": ["en-gb"]
    },
    {
      "filename": "**/brewfile",
      "enabled": false
    },
    {
      "filename": "**/justfile",
      "enabled": false
    }
  ]
}
