{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "en",
  "name": "AI Context Library",
  "description": "Spell checking configuration for Claude Code context files",
  "dictionaryDefinitions": [
    {
      "name": "project-words",
      "path": "${cwd}/.github/pre-commit/words/project.txt",
      "addWords": true
    },
    {
      "name": "tools-words",
      "path": "${cwd}/.github/pre-commit/words/tools.txt",
      "addWords": true
    }
  ],
  "dictionaries": [
    "typescript",
    "python",
    "bash",
    "go",
    "rust",
    "css",
    "html",
    "npm",
    "node",
    "softwareTerms",
    "companies",
    "misc",
    "project-words",
    "tools-words"
  ],
  "ignorePaths": [
    "node_modules/**",
    ".venv/**",
    "*.lock",
    "*.sql",
    "*.tex",
    "*.toml",
    "*.jsonl",
    ".beads/**",
    ".data/**",
    "dist/**",
    "build/**",
    "coverage/**",
    "*.min.*",
    ".git/**",
    ".github/pre-commit/words/**",
    "content/.content/**",
    "content/skills/**/examples/**",
    "content/skills/**/references/**",
    "content/skills/**/assets/**",
    "**/convert-*/**",
    "**/analysis.md",
    "**/schemas.md",
    "content/skills/.taxonomy.yaml",
    "content/skills/.TODO.yaml"
  ],
  "ignoreRegExpList": [
    "```[\\s\\S]*?```",
    "`[^`]+`",
    "\\[.*?\\]\\(.*?\\)",
    "https?://\\S+",
    "/[\\w-]+/[\\w-]+",
    "\\w+@\\w+\\.\\w+",
    "[a-f0-9]{7,40}",
    "\\$\\{.*?\\}",
    "\\{\\{.*?\\}\\}"
  ],
  "flagWords": [],
  "overrides": [
    {
      "filename": "**/*.md",
      "dictionaries": ["en-gb"]
    },
    {
      "filename": "**/brewfile",
      "enabled": false
    },
    {
      "filename": "**/justfile",
      "enabled": false
    }
  ]
}
